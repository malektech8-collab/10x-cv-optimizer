{
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ],
    "environmentVariables": {
      "FUNCTIONS_BASE_URL": "https://us-central1-x-cv-optimizer.cloudfunctions.net",
      "HOSTING_BASE_URL": "https://10-x.online"
    }
  },
  "firestore": {
    "indexes": "firestore.indexes.json"
  },
  "hosting": [
    {
      "target": "production",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/api/paymobWebhook",
          "function": "paymobWebhook",
          "region": "us-central1"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "staging",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/api/paymobWebhook",
          "function": "paymobWebhook",
          "region": "us-central1"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}